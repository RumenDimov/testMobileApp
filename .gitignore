# =========================
# Care Certificate & NVQ Practice App — .gitignore
# Stack: Expo (SDK 54+) + React Native + TypeScript + EAS
# =========================

# Documentation
/docs/

# Dependencies
node_modules/
.pnp/
.pnp.js

# Expo
.expo/
.expo-shared/
dist/
web-build/
expo-env.d.ts

# Native build output (generated by prebuild / EAS local builds)
/ios/
/android/
*.jks
*.p8
*.p12
*.key
*.mobileprovision
*.orig.*

# EAS
.easignore

# Metro / React Native
.metro-health-check*
*.jsbundle

# TypeScript
*.tsbuildinfo

# Local env files — never commit secrets (PostHog keys, IAP config, etc.)
.env
.env.local
.env.*.local

# SQLite local databases (seeded at runtime — do not commit device DB files)
*.db
*.sqlite
*.sqlite3

# Logs
npm-debug.*
yarn-debug.*
yarn-error.*
pnpm-debug.*
*.log

# Testing
/coverage/

# macOS
.DS_Store
*.pem

# Windows
Thumbs.db
ehthumbs.db

# Editor / IDE
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo

# Aider (AI coding workflow)
.aider*
.aider.tags.cache.v4/

# CodeRabbit / misc local tool caches
.coderabbit/

# Temporary files
*.tmp
*.temp
.cache/